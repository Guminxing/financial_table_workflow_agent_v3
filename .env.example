# Stage 11 Natural Language Agent — environment variables (placeholders only).
#
# Copy to `.env` and fill in real values. `.env` is git-ignored; NEVER commit
# real API keys. The project does NOT auto-load `.env` — set these in your
# shell environment before running `python -B src/chat_agent.py`.
#
# API key is read ONLY from the environment variable; it is placed in the HTTP
# Authorization header and never written to logs, events, or error messages.

# Your API key for an OpenAI-compatible provider.
FTA_LLM_API_KEY=sk-your-api-key-here

# OpenAI-compatible Chat Completions base URL.
# Examples:
#   OpenAI:        https://api.openai.com/v1
#   Azure OpenAI:  https://<resource>.openai.azure.com/openai/deployments/<deployment>
#   local / proxy: http://localhost:8000/v1
FTA_LLM_BASE_URL=https://api.openai.com/v1

# Model name supported by the provider (must support tool calling).
FTA_LLM_MODEL=gpt-4o-mini
