# Python cache
__pycache__/
*.pyc
*.pyo
*.pyd

# Virtual environments
.venv/
venv/
env/

# IDE / OS
.vscode/
.idea/
.DS_Store
Thumbs.db

# Logs
*.log

# Temporary files
*.tmp
*.bak

# ---- v3 directory policy -------------------------------------------------
# Real market data downloaded by the user at runtime (NOT committed).
data/real_market/*
!data/real_market/.gitkeep

# Formal pipeline outputs (NOT committed; regenerated each run).
outputs_real/*
!outputs_real/.gitkeep
outputs_real_verify/

# Output dirs the docs tell users to pass to --output_base / --output_root
# (NOT committed; created by following README.md / docs/LLM_AGENT.md / docs/PIPELINE.md).
outputs_agent/
outputs_chinese_report_smoke/

# Real data fetch cache + throwaway test outputs (NOT committed).
outputs/cache/
outputs/sessions/
outputs_norepair_test/

# Legacy synthetic-data paths (removed in v3; keep ignored in case of stragglers).
data/sample/
data/raw_real/
data/raw_real_verify/
data/**/_cache/

# Credentials / secrets — never commit.
.env
.env.*
!.env.example
*.key
*.pem
*.cookie
*token*.txt

# Test caches.
.pytest_cache/
